generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tbl_absensi {
  id_absen    BigInt     @id @default(autoincrement())
  id_siswi    BigInt?
  tanggal     DateTime   @db.Date
  waktu       String?    @db.VarChar(10)
  status      String?    @db.VarChar(20)
  keterangan  String?
  waktu_input DateTime?  @default(now()) @db.Timestamptz(6)
  metode      String?    @db.VarChar(10)
  tbl_siswi   tbl_siswi? @relation(fields: [id_siswi], references: [id_siswi], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tbl_grafik_data {
  id_data           BigInt     @id @default(autoincrement())
  bulan             Int?
  tahun             Int?
  id_kelas          BigInt?
  jumlah_hadir      Int?       @default(0)
  jumlah_haid       Int?       @default(0)
  jumlah_peringatan Int?       @default(0)
  tbl_kelas         tbl_kelas? @relation(fields: [id_kelas], references: [id_kelas], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tbl_kelas {
  id_kelas        BigInt            @id @default(autoincrement())
  nama_kelas      String            @db.VarChar(50)
  wali_kelas      String?           @db.VarChar(100)
  tbl_grafik_data tbl_grafik_data[]
  tbl_siswi       tbl_siswi[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tbl_log_aktivitas {
  id_log        BigInt     @id @default(autoincrement())
  id_user       BigInt?
  aktivitas     String?    @db.VarChar(255)
  tanggal_waktu DateTime?  @default(now()) @db.Timestamptz(6)
  keterangan    String?
  tbl_users     tbl_users? @relation(fields: [id_user], references: [id_user], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tbl_notifikasi {
  id_notif      BigInt     @id @default(autoincrement())
  id_siswi      BigInt?
  pesan         String?
  status_baca   String?    @db.VarChar(10)
  tanggal_kirim DateTime?  @default(now()) @db.Timestamptz(6)
  tbl_siswi     tbl_siswi? @relation(fields: [id_siswi], references: [id_siswi], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tbl_pengaturan_haid {
  id_setting          BigInt   @id @default(autoincrement())
  durasi_normal_min   Int?     @default(5)
  durasi_normal_max   Int?     @default(7)
  batas_suci_otomatis Int?     @default(8)
  notifikasi_aktif    Boolean? @default(true)
  pesan_peringatan    String?  @db.VarChar(255)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tbl_peringatan {
  id_peringatan      BigInt     @id @default(autoincrement())
  id_siswi           BigInt?
  tanggal_peringatan DateTime?  @db.Date
  jenis_peringatan   String?    @db.VarChar(50)
  status_baca        String?    @db.VarChar(10)
  tindakan_admin     String?
  tbl_siswi          tbl_siswi? @relation(fields: [id_siswi], references: [id_siswi], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tbl_periode_haid {
  id_periode      BigInt     @id @default(autoincrement())
  id_siswi        BigInt?
  tanggal_mulai   DateTime?  @db.Date
  tanggal_selesai DateTime?  @db.Date
  durasi          Int?
  status_selesai  String?    @db.VarChar(10)
  keterangan      String?    @db.VarChar(50)
  tbl_siswi       tbl_siswi? @relation(fields: [id_siswi], references: [id_siswi], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tbl_rekap_bulanan {
  id_rekap         BigInt     @id @default(autoincrement())
  id_siswi         BigInt?
  bulan            Int?
  tahun            Int?
  total_sholat     Int?       @default(0)
  total_haid       Int?       @default(0)
  total_hadir      Int?       @default(0)
  total_izin       Int?       @default(0)
  total_alfa       Int?       @default(0)
  total_peringatan Int?       @default(0)
  tbl_siswi        tbl_siswi? @relation(fields: [id_siswi], references: [id_siswi], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tbl_siswi {
  id_siswi          BigInt              @id @default(autoincrement())
  nis               String              @db.VarChar
  nama_lengkap      String              @db.VarChar
  id_kelas          BigInt?
  gender            String?             @default("Perempuan") @db.VarChar
  tanggal_lahir     DateTime?           @db.Date
  status_aktif      String?             @db.VarChar
  catatan           String?
  icode             String              @unique @db.VarChar(50)
  tbl_absensi       tbl_absensi[]
  tbl_notifikasi    tbl_notifikasi[]
  tbl_peringatan    tbl_peringatan[]
  tbl_periode_haid  tbl_periode_haid[]
  tbl_rekap_bulanan tbl_rekap_bulanan[]
  tbl_kelas         tbl_kelas?          @relation(fields: [id_kelas], references: [id_kelas], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tbl_users {
  id_user           BigInt              @id @default(autoincrement())
  nama_lengkap      String              @db.VarChar(100)
  username          String              @unique @db.VarChar(50)
  password          String              @db.VarChar(255)
  role              String?             @db.VarChar(20)
  last_login        DateTime?           @db.Timestamptz(6)
  foto_url          String?
  status_akun       String?             @default("Aktif") @db.VarChar
  status_kehadiran  String?             @default("Offline")
  tbl_log_aktivitas tbl_log_aktivitas[]
}
